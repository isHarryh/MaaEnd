{
    "AutoStockpileOOSEnsureStable": {
        "desc": "已售罄图标 (稳定标识)",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    10,
                    130,
                    45,
                    400
                ],
                "template": [
                    "AutoStockpile/OOS.png",
                    "AutoStockpile/OOSSelected.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        }
    },
    "AutoStockpileSelectMarket": {
        "desc": "将所有可购买物品展示在窗口中",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoStockpileFindMarketSidebar",
                    "AutoStockpileElasticGoodsSelected"
                ]
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    5,
                    5,
                    -10,
                    -10
                ]
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileMoveMouse"
        ]
    },
    "AutoStockpileTask": {
        "desc": "开始自动囤货任务",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileElasticGoodsButton",
            "AutoStockpileCheckInStore"
        ]
    },
    "AutoStockpileCheckInStore": {
        "desc": "检查商店图标，确认是否位于物资调度",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    50,
                    55,
                    60,
                    70
                ],
                "template": [
                    "AutoStockpile/StapleGoodsButtonSelected.png"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "focus": {
            "Node.Recognition.Succeeded": "该地区未解锁弹性物资调度，跳过该地区"
        }
    },
    "AutoStockpileElasticGoodsButton": {
        "desc": "弹性物资调度黑白双煞",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "AutoStockpileElasticGoods",
                    "AutoStockpileElasticGoodsSelected"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileGotoElasticGoods"
        ]
    },
    "AutoStockpileGotoElasticGoods": {
        "desc": "选择弹性物资调度",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoStockpileElasticGoodsButton",
                    "AutoStockpileOOSEnsureStable"
                ]
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_wait_freezes": {
            "time": 80,
            "target": [
                10,
                170,
                150,
                40
            ],
            "threshold": 0.98
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileSelectMarket"
        ]
    },
    "AutoStockpileFindMarketSidebar": {
        "desc": "识别侧边栏市场图标",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    15,
                    140,
                    40,
                    500
                ],
                "template": [
                    "AutoStockpile/ElasticGoodsButtonSide.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0
    },
    "AutoStockpileMoveMouse": {
        "desc": "避免鼠标遮挡",
        "pre_delay": 0,
        "action": {
            "type": "TouchMove",
            "param": {
                "target": [
                    1100,
                    50,
                    10,
                    10
                ]
            }
        },
        "post_wait_freezes": {
            "time": 80,
            "target": [
                15,
                160,
                40,
                150
            ],
            "threshold": 0.98
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "[Anchor]AutoStockpileDecision"
        ]
    },
    "AutoStockpileElasticGoods": {
        "desc": "弹性物资调度未选中",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    340,
                    55,
                    60,
                    70
                ],
                "template": [
                    "AutoStockpile/ElasticGoodsButton.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        }
    },
    "AutoStockpileElasticGoodsSelected": {
        "desc": "弹性物资调度选中",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    340,
                    55,
                    60,
                    70
                ],
                "template": [
                    "AutoStockpile/ElasticGoodsButtonSelected.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        }
    }
}
