{
    "task": [
        {
            "name": "AutoStockpile",
            "label": "$task.AutoStockpile.label",
            "entry": "AutoStockpileMain",
            "description": "$task.AutoStockpile.description",
            "controller": [
                "Win32-Window",
                "Win32-Window-Background",
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "daily"
            ],
            "option": [
                "AutoStockpileServerTime",
                "AutoStockpileValleyIV",
                "AutoStockpileWuling"
            ]
        }
    ],
    "option": {
        "AutoStockpileServerTime": {
            "type": "select",
            "label": "$task.AutoStockpile.option.AutoStockpileServerTime.label",
            "description": "$task.AutoStockpile.option.AutoStockpileServerTime.description",
            "default_case": "CN_UTC_PLUS_8",
            "cases": [
                {
                    "name": "CN_UTC_PLUS_8",
                    "label": "$task.AutoStockpile.option.AutoStockpileServerTime.cases.CN_GMT_PLUS_8.label",
                    "pipeline_override": {
                        "AutoStockpileAttach": {
                            "attach": {
                                "server_time": 8
                            }
                        }
                    }
                },
                {
                    "name": "ASIA_UTC_PLUS_9",
                    "label": "$task.AutoStockpile.option.AutoStockpileServerTime.cases.ASIA_GMT_PLUS_9.label",
                    "pipeline_override": {
                        "AutoStockpileAttach": {
                            "attach": {
                                "server_time": 9
                            }
                        }
                    }
                },
                {
                    "name": "US_UTC_MINUS_8",
                    "label": "$task.AutoStockpile.option.AutoStockpileServerTime.cases.US_GMT_MINUS_8.label",
                    "pipeline_override": {
                        "AutoStockpileAttach": {
                            "attach": {
                                "server_time": -8
                            }
                        }
                    }
                },
                {
                    "name": "EU_UTC_PLUS_1",
                    "label": "$task.AutoStockpile.option.AutoStockpileServerTime.cases.EU_GMT_PLUS_1.label",
                    "pipeline_override": {
                        "AutoStockpileAttach": {
                            "attach": {
                                "server_time": 1
                            }
                        }
                    }
                }
            ]
        },
        "AutoStockpileValleyIV": {
            "type": "switch",
            "label": "$task.AutoStockpile.option.AutoStockpileValleyIV.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoStockpileValleyIV": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "AutoStockpileWuling": {
            "type": "switch",
            "label": "$task.AutoStockpile.option.AutoStockpileWuling.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoStockpileWuling": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        }
    }
}
