{
    "task": [
        {
            "name": "AutoEcoFarm",
            "label": "$task.AutoEcoFarm.label",
            "entry": "AutoEcoFarmMain",
            "description": "$task.AutoEcoFarm.description",
            "controller": [
                "Win32-Front"
            ],
            "option": [
                "FarmlandFindingScheme"
            ]
        }
    ],
    "option": {
        "FarmlandFindingScheme": {
            "type": "select",
            "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.label",
            "default_case": "BRtoTL",
            "cases": [
                {
                    "name": "BRtoTL",
                    "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.cases[1].label",
                    "pipeline_override": {
                        "_AutoEcoFarmFindFarmland": {
                            "recognition": {
                                "type": "TemplateMatch",
                                "param": {
                                    "order_by": "Horizontal"
                                }
                            }
                        },
                        "_AutoEcoFarmFindValleyIVEcoFarmAny": {
                            "enabled": false
                        }
                    }
                }
                //{
                //    "name": "多次随机找田（没做完）",
                //   "label": "多次随机找田，bug比较多",
                //    "pipeline_override": {
                //        "_AutoEcoFarmFindFarmland": {
                //            "recognition": {
                //                "type": "TemplateMatch",
                //                "param": {
                //                    "order_by": "Random"
                //                }
                //            }
                //        },
                //        "_AutoEcoFarmFindValleyIVEcoFarmAny": {
                //            "enabled": true
                //        }
                //    }
                //}
            ]
        }
    }
}
