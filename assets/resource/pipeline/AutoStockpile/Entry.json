{
    "AutoStockpileElasticGoodsButton": {
        "desc": "弹性物资调度黑白双煞",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "AutoStockpileElasticGoods",
                    "AutoStockpileElasticGoodsSelected"
                ]
            }
        }
    },
    "AutoStockpileSelectMarket": {
        "desc": "将所有可购买物品展示在窗口中",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoStockpileFindMarketSidebar",
                    "AutoStockpileElasticGoodsSelected"
                ]
            }
        },
        "pre_wait_freezes": 80,
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    5,
                    5,
                    -10,
                    -10
                ]
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileEnaureElasticClicked"
        ]
    },
    "AutoStockpileTask": {
        "desc": "开始自动囤货任务",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileGotoElasticGoods",
            "AutoStockpileCheckInStore"
        ]
    },
    "AutoStockpileCheckInStore": {
        "desc": "检查商店图标，确认是否位于物资调度",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    50,
                    55,
                    60,
                    70
                ],
                "template": [
                    "AutoStockpile/StableGoodsButtonSelected.png"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "focus": {
            "Node.Recognition.Succeeded": "该地区未解锁弹性物资调度，跳过该地区"
        }
    },
    "AutoStockpileGotoElasticGoods": {
        "desc": "选择弹性物资调度",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoStockpileElasticGoodsButton"
                ]
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileSelectMarket"
        ]
    },
    "AutoStockpileFindMarketSidebar": {
        "desc": "识别侧边栏市场图标",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    15,
                    140,
                    40,
                    500
                ],
                "template": [
                    "AutoStockpile/ElasticGoodsButtonSide.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0
    },
    "AutoStockpileElasticGoods": {
        "desc": "弹性物资调度未选中",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    340,
                    55,
                    60,
                    70
                ],
                "template": [
                    "AutoStockpile/ElasticGoodsButton.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        }
    },
    "AutoStockpileElasticGoodsSelected": {
        "desc": "弹性物资调度选中",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    340,
                    55,
                    60,
                    70
                ],
                "template": [
                    "AutoStockpile/ElasticGoodsButtonSelected.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        }
    },
    "AutoStockpileEnaureElasticClicked": {
        "desc": "确保成功点击了弹性物资调度",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    15,
                    140,
                    40,
                    500
                ],
                "template": [
                    "AutoStockpile/ElasticGoodsButtonSideSelected.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        },
        "next": [
            "[Anchor]AutoStockpileDecision"
        ]
    }
}
